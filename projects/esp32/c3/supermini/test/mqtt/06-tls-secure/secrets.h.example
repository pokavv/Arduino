// secrets.h.example — 형식만 담은 예시 (실제 값 없음)
// secrets.h 로 복사 후 실제 값 입력 (secrets.h는 Git 제외)
#pragma once

const char* WIFI_SSID     = "YOUR_WIFI_SSID";
const char* WIFI_PASSWORD = "YOUR_WIFI_PASSWORD";

// TLS MQTT 브로커 주소 (포트 8883 사용)
const char* MQTT_SERVER   = "YOUR_MQTT_BROKER";   // 예: broker.hivemq.com
const int   MQTT_PORT     = 8883;                   // TLS 표준 포트

// (선택) MQTT 브로커 인증 정보
const char* MQTT_USER     = "";   // 인증 없으면 빈 문자열
const char* MQTT_PASS     = "";

// (선택) CA 인증서 — TLS_INSECURE_MODE=0일 때 필요
// 브로커의 CA 인증서를 PEM 형식으로 아래에 붙여넣기
// const char* CA_CERT = "-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n";
