/*
 * 1-01 디지털 출력 — LED 켜고 끄기
 * ================================================================
 *
 * [하드웨어 기초 용어]
 *
 *  GND (접지)
 *    전기의 기준점. 배터리의 - 극과 같은 개념.
 *    모든 부품은 GND가 연결되어야 전기가 흐른다.
 *    보드에 'GND' 또는 'G' 핀이 여러 개 있음 — 다 같은 GND다.
 *
 *  3.3V 핀
 *    보드에서 3.3V 전압이 항상 나오는 핀. 전원 역할.
 *    5V를 쓰면 보드가 망가지므로 주의!
 *
 *  G0, G2, G9 ... (GPIO 핀)
 *    보드 가장자리에 줄지어 있는 핀들.
 *    보드 겉면에 숫자가 적혀 있다 (G2, G8, G9 등).
 *    코드로 전기를 내보내거나(출력), 읽어오거나(입력) 할 수 있다.
 *
 *  HIGH / LOW
 *    HIGH = 전기 있음 = 3.3V
 *    LOW  = 전기 없음 = 0V (GND 수준)
 *
 *  저항 (220Ω, 220옴)
 *    전류를 줄여주는 부품. 생긴 건 원통형에 줄무늬.
 *    LED에 저항을 안 달면 → 전류가 너무 많이 흘러 → LED가 탄다.
 *    220Ω짜리 사용하면 안전하게 LED를 켤 수 있다.
 *
 *  LED
 *    빛을 내는 부품. 다리가 2개다.
 *    긴 다리(+, 양극) → 전기 들어오는 쪽
 *    짧은 다리(-, 음극) → 전기 나가는 쪽 (GND 쪽)
 *    방향이 바뀌면 빛이 안 난다.
 *
 * ================================================================
 * [이 예제에서 하는 것]
 *   G2 핀에서 전기를 내보내면 → LED 켜짐
 *   G2 핀 전기를 멈추면 → LED 꺼짐
 *   1초 간격으로 반복
 *
 * [주의]
 *   이건 따로 연결한 LED 예제다.
 *   보드에 붙어있는 내장 LED를 켜려면 → 02-builtin-led 사용
 *
 * [준비물]
 *   LED 1개, 220Ω 저항 1개, 점퍼 와이어
 *
 * [연결 방법]
 *   ESP32 G2 핀 → 저항(220Ω) → LED 긴 다리(+) → LED 짧은 다리(-) → ESP32 GND 핀
 *
 *   그림으로 보면:
 *   [G2]──[저항]──[LED+]──[LED-]──[GND]
 */

#include "config.h"

void setup() {
    Serial.begin(115200);

    // G2 핀을 "출력 모드"로 설정
    // 출력 모드 = 이 핀에서 전기를 내보낼 것이라고 선언
    pinMode(LED_PIN, OUTPUT);

    Serial.println("시작! G2 핀에 LED를 연결했다면 깜빡일 거야");
}

void loop() {
    digitalWrite(LED_PIN, HIGH);   // G2 핀에서 3.3V 내보내기 → LED 켜짐
    Serial.println("LED 켜짐");
    delay(1000);                   // 1000ms = 1초 기다리기

    digitalWrite(LED_PIN, LOW);    // G2 핀 전압 0V → LED 꺼짐
    Serial.println("LED 꺼짐");
    delay(1000);
}
