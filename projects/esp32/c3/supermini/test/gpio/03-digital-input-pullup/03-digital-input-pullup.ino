/*
 * 1-03 버튼 입력 읽기 (PULLUP 방식)
 * ================================================================
 *
 * [버튼이란?]
 *   누르면 두 다리가 연결되고, 떼면 끊어지는 부품.
 *   보드에 'BOOT'라고 적힌 작은 버튼이 이미 G9 핀에 연결되어 있다.
 *   따로 버튼을 사지 않아도 이 예제를 테스트할 수 있다.
 *
 * [외부 버튼을 추가로 쓰고 싶다면 연결 방법]
 *   버튼 한쪽 다리 → G9 핀
 *   버튼 반대쪽 다리 → GND 핀
 *   저항은 필요 없음 (INPUT_PULLUP이 내부 저항 역할을 해줌)
 *
 * [INPUT_PULLUP이란?]
 *   버튼을 GND에 연결하면 누를 때 전압이 0V(LOW)가 된다.
 *   그런데 버튼을 안 눌렀을 때 핀이 공중에 뜬 상태가 되면
 *   노이즈 때문에 값이 불안정해진다.
 *   INPUT_PULLUP을 쓰면 내부에서 3.3V 저항으로 핀을 당겨주어
 *   버튼 안 누른 상태에서 안정적으로 HIGH를 유지한다.
 *
 * [버튼 상태 정리]
 *   버튼 안 누름 → 핀이 내부 저항으로 3.3V 유지 → HIGH 읽힘
 *   버튼 누름    → 핀이 GND에 직결 → 0V → LOW 읽힘
 *   (눌렀을 때 LOW가 나오는 게 처음엔 헷갈릴 수 있다!)
 *
 * [준비물]
 *   없음 — 보드의 BOOT 버튼(G9) 사용
 */

#include "config.h"

void setup() {
    Serial.begin(115200);

    // G9 핀을 입력 모드 + 내부 풀업 저항 사용으로 설정
    pinMode(BUTTON_PIN, INPUT_PULLUP);

    Serial.println("시작! 보드의 BOOT 버튼을 눌러봐");
    Serial.println("(BOOT 버튼은 보드 위에 작은 버튼이야)");
}

void loop() {
    int state = digitalRead(BUTTON_PIN);   // 현재 핀 전압 읽기

    if (state == LOW) {
        // LOW = 버튼이 GND에 연결됨 = 버튼 눌린 상태
        Serial.println("버튼 눌렸어!");
    } /*else {
        // HIGH = 내부 저항이 3.3V 유지 = 버튼 안 눌린 상태
        Serial.println("버튼 안 눌림");
    }*/

    delay(200);   // 0.2초마다 확인 (너무 빠르면 시리얼 모니터가 도배됨)
}
