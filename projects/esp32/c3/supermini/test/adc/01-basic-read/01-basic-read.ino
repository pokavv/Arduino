/*
 * 2-01 아날로그 값 읽기 기초
 * ================================================================
 *
 * [디지털 vs 아날로그]
 *   디지털: 켜짐(1) / 꺼짐(0) 두 가지만 존재
 *   아날로그: 0V ~ 3.3V 사이 어느 전압이든 가능 (연속적인 값)
 *
 * [아날로그 입력이 필요한 상황 예시]
 *   가변저항 손잡이 위치, 밝기 감지, 온도, 배터리 잔량 등
 *   "켜짐/꺼짐"이 아니라 "얼마나?"를 알아야 할 때 사용
 *
 * [analogRead() 함수]
 *   핀의 전압을 숫자로 변환해서 돌려준다.
 *   ESP32-C3: 0V → 0,  3.3V → 4095  (12비트 = 4096 단계)
 *   일반 아두이노(우노): 0V → 0, 5V → 1023 (10비트 = 1024 단계)
 *   ESP32가 더 세밀하게 읽을 수 있다.
 *
 * [아날로그 읽기 가능한 핀 — ESP32-C3 Super Mini]
 *   G0, G1, G2, G3, G4 핀만 가능
 *   나중에 Wi-Fi를 켜면 G5 이상 핀의 아날로그 읽기가 망가지므로
 *   아날로그 센서는 G0~G4에 연결하는 게 좋다.
 *
 * [준비물]
 *   가변저항(포텐셔미터) 1개
 *
 * [연결 방법]
 *   가변저항 왼쪽 다리  → GND 핀
 *   가변저항 가운데 다리 → G0 핀  ← 이 전압을 읽는다
 *   가변저항 오른쪽 다리 → 3.3V 핀
 *   (어느 쪽이 왼쪽인지 모르면 한 방향으로 꽂고 반대로도 해봐)
 */

#include "config.h"

void setup() {
    Serial.begin(115200);
    Serial.println("시작! 가변저항을 돌려봐 — 숫자가 0~4095 사이에서 변해");
}

void loop() {
    int raw = analogRead(ADC_PIN);   // G0 핀 전압을 0~4095 숫자로 읽기
    Serial.print("읽은 값: ");
    Serial.println(raw);
    delay(500);
}
