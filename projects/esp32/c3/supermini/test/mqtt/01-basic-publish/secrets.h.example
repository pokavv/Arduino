// secrets.h.example — 실제 값 없이 형식만 담은 예시 파일
// 이 파일을 복사해 secrets.h 로 저장 후 실제 값 입력
// secrets.h 는 Git에 포함되지 않음 (.gitignore)
#pragma once

const char* WIFI_SSID     = "YOUR_WIFI_SSID";
const char* WIFI_PASSWORD = "YOUR_WIFI_PASSWORD";
const char* MQTT_SERVER   = "YOUR_MQTT_BROKER";   // IP 또는 도메인 (예: 192.168.1.100)
const int   MQTT_PORT     = 1883;
