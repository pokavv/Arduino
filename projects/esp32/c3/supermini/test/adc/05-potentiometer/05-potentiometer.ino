/*
 * 2-05 가변저항으로 값 조절하기
 * ================================================================
 *
 * [가변저항(포텐셔미터)이란?]
 *   손잡이를 돌리면 저항값이 바뀌는 부품.
 *   저항값이 바뀌면 핀에 걸리는 전압이 0V~3.3V 사이에서 변한다.
 *   볼륨 조절 다이얼, 조이스틱 등에 사용되는 원리와 같다.
 *   다리가 3개:
 *     양쪽 끝 다리 → 전압 범위 결정 (GND 와 3.3V에 연결)
 *     가운데 다리  → 손잡이 위치에 따른 전압 출력 (G0에 연결)
 *
 * [map() 함수란?]
 *   숫자 범위를 다른 범위로 비례해서 변환해주는 함수.
 *   형식: map(값, 현재_최솟값, 현재_최댓값, 바꿀_최솟값, 바꿀_최댓값)
 *
 *   예시:
 *   map(2048, 0, 4095, 0, 100) → 50  (정확히 중간이면 50%)
 *   map(4095, 0, 4095, 0, 100) → 100 (최대면 100%)
 *   map(0,    0, 4095, 0, 100) → 0   (최소면 0%)
 *
 * [준비물]
 *   가변저항 1개
 *
 * [연결 방법]
 *   가변저항 왼쪽 다리  → GND
 *   가변저항 가운데 다리 → G0
 *   가변저항 오른쪽 다리 → 3.3V
 */

#include "config.h"

void setup() {
    Serial.begin(115200);
    Serial.println("시작! 가변저항을 돌려봐");
}

void loop() {
    int raw = analogRead(POT_PIN);

    // 0~4095 숫자를 0~100 퍼센트로 변환
    int percent = map(raw, 0, 4095, 0, 100);

    float voltage = raw * (3.3f / 4095.0f);

    Serial.print("숫자: ");
    Serial.print(raw);
    Serial.print("  전압: ");
    Serial.print(voltage, 2);
    Serial.print("V  퍼센트: ");
    Serial.print(percent);
    Serial.println("%");

    delay(200);
}
