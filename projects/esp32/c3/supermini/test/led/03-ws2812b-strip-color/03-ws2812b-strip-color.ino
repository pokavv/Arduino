/**
 * @file  03-ws2812b-strip-color.ino
 * @brief WS2812B 8개 스트립 - 각 LED 다른 색 + 무지개 패턴
 *
 * ---------------------------------------------------------------
 * [핵심 개념]
 * WS2812B를 여러 개 직렬 연결하면 하나의 데이터 선으로
 * 모든 LED를 독립적으로 제어할 수 있습니다.
 *
 * HSV 색상 모델:
 * - H (Hue, 색조)       : 0~255 = 색의 종류 (빨→주→노→초→파→보→빨)
 * - S (Saturation, 채도): 0~255 = 색의 진함 (0=흰색, 255=순색)
 * - V (Value, 명도)     : 0~255 = 밝기 (0=검정, 255=최대밝기)
 *
 * CHSV(hue, sat, val)를 사용하면 무지개 색상을 쉽게 만들 수 있습니다.
 * FastLED가 내부적으로 HSV → RGB 변환을 처리합니다.
 *
 * 무지개 패턴 원리:
 * - 각 LED에 순서대로 다른 hue 값을 적용합니다.
 * - hue 시작값을 매 프레임 증가시키면 색상이 흘러가 보입니다.
 * ---------------------------------------------------------------
 * [라이브러리]
 * - FastLED (Arduino IDE → 라이브러리 관리 → "FastLED" 검색)
 * ---------------------------------------------------------------
 * [준비물]
 * - ESP32-C3 Super Mini x1
 * - WS2812B LED 스트립 (8개) x1
 * - 470Ω 저항 x1 (데이터 선)
 * - 1000μF 전해 콘덴서 x1 (전원 안정화)
 * - 외부 5V 전원 (LED 8개 이상은 ESP32 전원만으로 부족할 수 있음)
 * ---------------------------------------------------------------
 * [연결 방법]
 * WS2812B 스트립:
 *   VCC  → 외부 5V (또는 ESP32 3V3, 개수 적을 때)
 *   GND  → GND (외부 전원과 ESP32 GND 공통 연결 필수!)
 *   DIN  → 470Ω 저항 → ESP32 G2
 *
 * ※ 외부 5V 전원 사용 시 GND를 반드시 ESP32 GND와 연결하세요.
 * ---------------------------------------------------------------
 */

#include <FastLED.h>
#include "config.h"

// ---------------------------------------------------------------
// LED 배열 (LED_COUNT개의 색상 저장)
// ---------------------------------------------------------------
CRGB leds[LED_COUNT];

// 무지개 hue 시작값 (0~255 순환)
uint8_t startHue = 0;

// millis() 타이머
unsigned long lastUpdateMs = 0;

// ---------------------------------------------------------------
// 함수 선언
// ---------------------------------------------------------------
void showRainbow();

// ---------------------------------------------------------------
// setup(): 초기화
// ---------------------------------------------------------------
void setup() {
    Serial.begin(BAUD_RATE);
    Serial.println("===== WS2812B 스트립 무지개 패턴 =====");
    Serial.printf("LED 개수: %d개\n", LED_COUNT);

    FastLED.addLeds<WS2812B, LED_PIN, GRB>(leds, LED_COUNT);
    FastLED.setBrightness(BRIGHTNESS);

    // 시작 시 모든 LED 끄기
    FastLED.clear();
    FastLED.show();

    Serial.println("무지개 패턴 시작!");
}

// ---------------------------------------------------------------
// loop(): 메인 루프
// ---------------------------------------------------------------
void loop() {
    unsigned long now = millis();

    if (now - lastUpdateMs >= UPDATE_DELAY_MS) {
        lastUpdateMs = now;
        showRainbow();
    }
}

// ---------------------------------------------------------------
// showRainbow(): 무지개 패턴을 표시합니다.
// 각 LED에 hue 값을 고르게 분배하고, 매 프레임 hue를 이동시킵니다.
// ---------------------------------------------------------------
void showRainbow() {
    // LED 8개에 걸쳐 hue가 한 바퀴 돌도록 간격 계산
    // 256 / LED_COUNT = 각 LED 간 hue 차이
    uint8_t hueStep = 256 / LED_COUNT;

    for (int i = 0; i < LED_COUNT; i++) {
        // CHSV: hue(색조), saturation(채도=255=순색), value(밝기=255)
        leds[i] = CHSV(startHue + (i * hueStep), 255, 255);
    }

    // startHue를 1씩 증가시켜 색상이 흘러가는 효과
    startHue++;   // uint8_t라서 255 다음에 자동으로 0으로 돌아옴

    FastLED.show();
}
