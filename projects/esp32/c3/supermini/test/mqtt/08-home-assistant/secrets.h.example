// secrets.h.example — 형식만 담은 예시 (실제 값 없음)
// secrets.h 로 복사 후 실제 값 입력 (secrets.h는 Git 제외)
// Home Assistant와 같은 네트워크의 Mosquitto 브로커 사용 권장
#pragma once

const char* WIFI_SSID     = "YOUR_WIFI_SSID";
const char* WIFI_PASSWORD = "YOUR_WIFI_PASSWORD";
const char* MQTT_SERVER   = "YOUR_HA_IP";      // HA 서버 IP (예: 192.168.1.100)
const int   MQTT_PORT     = 1883;
const char* MQTT_USER     = "YOUR_MQTT_USER";  // HA Mosquitto 사용자
const char* MQTT_PASS     = "YOUR_MQTT_PASS";
