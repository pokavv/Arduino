/**
 * @file  02-ap-mode.ino
 * @brief Wi-Fi AP(Access Point) 모드 예제
 *
 * ---------------------------------------------------------------
 * [핵심 개념]
 * AP(Access Point) 모드:
 * - ESP32가 직접 공유기 역할을 합니다.
 * - 스마트폰이나 노트북이 ESP32가 만든 Wi-Fi에 접속할 수 있습니다.
 * - 인터넷 연결은 없지만, 기기 간 직접 통신이 가능합니다.
 * - 주로 초기 설정, 로컬 제어에 사용합니다.
 *
 * AP 모드의 기본 IP:
 * - ESP32 AP 모드의 기본 게이트웨이 IP: 192.168.4.1
 * - 접속한 클라이언트는 192.168.4.x 대역 IP를 받습니다.
 *
 * secrets.h 불필요:
 * - AP 모드는 ESP32가 공유기 역할이므로 외부 Wi-Fi 인증 정보 불필요
 * ---------------------------------------------------------------
 * [라이브러리]
 * - WiFi.h (ESP32 Arduino 내장)
 * ---------------------------------------------------------------
 * [준비물]
 * - ESP32-C3 Super Mini x1
 * - Wi-Fi 접속 가능한 스마트폰 또는 노트북 (테스트용)
 * ---------------------------------------------------------------
 * [연결 방법]
 * - 하드웨어 연결 없음
 * - 업로드 후 스마트폰 Wi-Fi에서 "ESP32-C3-AP" 선택
 * - 비밀번호: 12345678
 * ---------------------------------------------------------------
 */

#include <WiFi.h>
#include "config.h"

// ---------------------------------------------------------------
// 함수 선언
// ---------------------------------------------------------------
void startAP();
void printAPInfo();

// ---------------------------------------------------------------
// setup(): AP 시작
// ---------------------------------------------------------------
void setup() {
    Serial.begin(BAUD_RATE);
    delay(500);
    Serial.println("\n===== Wi-Fi AP 모드 =====");

    startAP();
    printAPInfo();
}

// ---------------------------------------------------------------
// loop(): 연결된 클라이언트 수 주기적 출력
// ---------------------------------------------------------------
void loop() {
    // WiFi.softAPgetStationNum() = 현재 접속한 클라이언트 수
    int clientCount = WiFi.softAPgetStationNum();
    Serial.printf("[AP 상태] 접속 클라이언트: %d대\n", clientCount);

    delay(5000);   // 5초마다 확인
}

// ---------------------------------------------------------------
// startAP(): AP 모드를 시작합니다.
// ---------------------------------------------------------------
void startAP() {
    // AP 모드로 설정
    WiFi.mode(WIFI_AP);

    // AP 생성: softAP(SSID, 비밀번호, 채널, 숨김여부, 최대접속수)
    bool result = WiFi.softAP(AP_SSID, AP_PASSWORD, AP_CHANNEL, 0, AP_MAX_CLIENTS);

    if (result) {
        Serial.println("[AP] 생성 성공!");
    } else {
        Serial.println("[AP] 생성 실패! 설정 확인 필요");
    }
}

// ---------------------------------------------------------------
// printAPInfo(): AP 정보를 시리얼로 출력합니다.
// ---------------------------------------------------------------
void printAPInfo() {
    Serial.println("----------------------------");
    Serial.printf("  AP SSID  : %s\n", AP_SSID);
    Serial.printf("  비밀번호  : %s\n", AP_PASSWORD);
    Serial.printf("  AP IP    : %s\n", WiFi.softAPIP().toString().c_str());
    Serial.printf("  MAC 주소 : %s\n", WiFi.softAPmacAddress().c_str());
    Serial.println("----------------------------");
    Serial.println("스마트폰에서 위 AP에 접속해보세요!");
}
